{
  "name": "@processfox/runtime",
  "version": "0.0.0",
  "description": "ProcessFox runtime/player: executes an app manifest in the browser and renders the module UIs + data-flow panel",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:player": "vite build --config vite.player.config.ts",
    "export": "tsx src/export/exportApp.ts",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@processfox/core": "0.0.0",
    "docxtemplater": "^3.50.0",
    "file-saver": "^2.0.5",
    "pizzip": "^3.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.12",
    "@types/node": "^22.10.2",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.8"
  }
}
